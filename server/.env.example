# 照片上传服务器配置

# 上传目录（服务器上的绝对路径）
UPLOAD_DIR=/var/guyue/s.guyue.me/starstill

# 认证凭证
UPLOAD_USER=admin
UPLOAD_PASS=your_secure_password_here

# 服务器端口
PORT=2655

# ImageMagick 命令 (magick 或 convert)
IMAGEMAGICK_COMMAND=magick

# 缩略图配置
THUMB_WIDTH=800
THUMB_QUALITY=82

# 基础路径前缀（用于通过 Nginx 反向代理访问）
# 例如: /starstill/manage
# 留空表示不使用基础路径
BASE_PATH=

# 图片基础 URL（前端用来显示缩略图）
# 相对路径: /starstill/img 或 绝对路径: https://s.guyue.me/starstill/img
IMAGE_BASE_URL=/starstill/img
